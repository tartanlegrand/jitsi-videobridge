# =============================================================================
# Jitsi Videobridge — GraalVM Native Image Agent
# =============================================================================
# Runs JVB on the JVM with the native-image-agent attached to capture
# reflection, proxy, resource, and serialization metadata needed for
# native image compilation.
#
# Usage:
#   docker build -f Dockerfile.agent -t jvb-agent .
#   docker run --network host -v $(pwd)/config-output:/app/config-output jvb-agent
#
# After running, use convert_metadata.py to merge the agent output with
# any manually-added entries into config-full/.
# =============================================================================

FROM maven:3.9.9-eclipse-temurin-21 AS builder

WORKDIR /app

COPY pom.xml .
COPY jvb/pom.xml jvb/
COPY rtp/pom.xml rtp/
COPY jitsi-media-transform/pom.xml jitsi-media-transform/
COPY config config/
COPY jvb/src jvb/src
COPY rtp/src rtp/src
COPY jitsi-media-transform/src jitsi-media-transform/src

RUN mvn clean package -pl jvb -am -P buildFatJar -DskipTests

FROM ghcr.io/graalvm/native-image-community:25

WORKDIR /app

COPY --from=builder /app/jvb/target/jitsi-videobridge-*-jar-with-dependencies.jar jvb.jar
COPY config-full config/

RUN mkdir -p /app/config-output && chmod 777 /app/config-output

# The native-image-agent traces all reflection/proxy/resource usage at runtime
# and writes config files to config-output/ every 10 seconds.
# Exercise all JVB endpoints while this is running to capture complete metadata.
ENTRYPOINT ["java", "-agentlib:native-image-agent=config-output-dir=/app/config-output,config-write-period-secs=10", "-Dvideobridge.http-servers.private.host=0.0.0.0", "-jar", "jvb.jar"]
